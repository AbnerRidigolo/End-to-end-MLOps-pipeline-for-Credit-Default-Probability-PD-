# ── HuggingFace (opcional — sem token usa fallback de templates) ──────────────
# Crie em: https://huggingface.co/settings/tokens → New token → Read
HF_TOKEN=seu-token-hf-aqui
# Modelos suportados:
#   mistralai/Mistral-7B-Instruct-v0.3   <- padrão recomendado
#   HuggingFaceH4/zephyr-7b-beta         <- boa qualidade em PT-BR, sem restrição
#   meta-llama/Meta-Llama-3-8B-Instruct  <- alternativa (requer aceite de licença no HF)
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# ── API FastAPI (OBRIGATÓRIO) ─────────────────────────────────────────────────
# Token Bearer para autenticação nos endpoints da API
API_TOKEN=troque-por-um-token-seguro-aqui

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=troque-por-senha-segura
POSTGRES_DB=airflow

# ── MinIO (S3-compatível) ─────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=troque-por-senha-segura

# ── Airflow ───────────────────────────────────────────────────────────────────
# Gere uma nova chave: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nfdstM=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=troque-por-senha-segura
AIRFLOW_ADMIN_EMAIL=admin@credito.local
